# --- MongoDB ---
# https://cloud.mongodb.com → Database → Connect → "Drivers"
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ideainshaat?retryWrites=true&w=majority

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth ---
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Allowlisted admin emails (comma-separated). Only these Google accounts can sign in.
ADMIN_EMAILS=fuadbagiyev@gmail.com

# --- Cloudinary ---
# https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# --- Mail (existing) ---
SMTP_USER=
SMTP_PASS=
CONTACT_TO=
